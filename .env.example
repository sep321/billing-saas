# Nginx / Web service port on the host
APP_PORT=8080

# PostgreSQL Database Connection (Main Application DB)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=isp_billing
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis Connection
REDIS_HOST=redis
REDIS_PORT=6379

# MySQL Database Connection (Only for FreeRADIUS service)
MYSQL_RADIUS_HOST=mysql
MYSQL_RADIUS_DATABASE=radius
MYSQL_RADIUS_USERNAME=radius
MYSQL_RADIUS_PASSWORD=radius123
